[Unit]
Description=PeopleHub - Sistema de Gestão de Pessoas
After=network.target postgresql.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/peoplehub
EnvironmentFile=/opt/peoplehub/.env
Environment="PATH=/opt/peoplehub/venv/bin"
ExecStart=/opt/peoplehub/venv/bin/gunicorn -c gunicorn.conf.py backend.app:app
ExecReload=/bin/kill -s HUP $MAINPID
Restart=on-failure
RestartSec=5s
StandardOutput=append:/var/log/peoplehub/app.log
StandardError=append:/var/log/peoplehub/error.log

[Install]
WantedBy=multi-user.target
